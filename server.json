{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.ParadoxInfinite/oriel",
  "description": "Safety-gated AI control of Docker and Colima: containers, images, volumes, networks, Compose.",
  "repository": {
    "url": "https://github.com/ParadoxInfinite/oriel",
    "source": "github"
  },
  "version": "0.7.0",
  "packages": [
    {
      "registryType": "oci",
      "identifier": "ghcr.io/paradoxinfinite/oriel:0.7.0",
      "transport": {
        "type": "stdio"
      },
      "runtimeHint": "docker",
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "--rm"
        },
        {
          "type": "named",
          "name": "-v",
          "value": "/var/run/docker.sock:/var/run/docker.sock"
        }
      ]
    }
  ]
}